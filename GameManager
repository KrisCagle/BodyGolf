-- Call this function to START the game for a player
function GameManager.StartGame(player)
	print("Starting game for " .. player.Name)

	-- Set the active hole number using your HoleManager
	HoleManager.CurrentHole = 1

	-- Set the player's state so the launch button will work
	player:SetAttribute("InGame", true)

	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		-- Lock player movement
		humanoid.WalkSpeed = 0
		humanoid.JumpPower = 0
		humanoid.JumpHeight = 0
	end

	-- Teleport the player to Hole 1
	teleportPlayer(player, SPAWN_LOCATIONS.Hole1)
end

